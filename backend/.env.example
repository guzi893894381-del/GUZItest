# ============================================
# 环境变量示例
# 复制此文件为 .env，然后填入你的配置
# ============================================

# Flask 环境
FLASK_ENV=development
FLASK_DEBUG=True

# 数据库
DATABASE_URL=sqlite:///./database/products.db

# 代理配置（可选）
# PROXY_URL=http://proxy-ip:port
# PROXY_USERNAME=username
# PROXY_PASSWORD=password

# 日志级别
LOG_LEVEL=INFO
